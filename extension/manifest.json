{
  "manifest_version": 3,
  "name": "MeetRec - Google Meet Audio Recorder",
  "version": "1.0",
  "description": "Record Google Meet audio with one click directly from the toolbar.",
  "permissions": [
    "tabCapture",
    "scripting",
    "activeTab",
    "tabs",
    "storage",
    "offscreen",
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "css": [
        "content_style.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "offscreen.js"
      ],
      "matches": [
        "https://meet.google.com/*"
      ]
    }
  ]
}